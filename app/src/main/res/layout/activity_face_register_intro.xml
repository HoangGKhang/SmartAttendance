<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/faceRegisterScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/faceRegisterRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="72dp"
        android:paddingBottom="32dp">

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/faceLogoContainer"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:background="@drawable/face_bg_logo_green">

            <ImageView
                android:id="@+id/imgFaceLogo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:contentDescription="Biểu tượng khuôn mặt"
                android:src="@drawable/face_ic_user"
                app:tint="#000000" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvFaceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="Đăng ký khuôn mặt"
            android:textColor="#111827"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFaceSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="Bước này giúp hệ thống xác minh đúng sinh viên khi điểm danh."
            android:textColor="#4F647B"
            android:textSize="14sp" />

        <!-- Info card -->
        <LinearLayout
            android:id="@+id/faceInfoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/face_bg_card"
            android:orientation="vertical">

            <!-- Item 1 -->
            <LinearLayout
                android:id="@+id/itemEasy"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/face_bg_icon_green">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="#15935B"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dễ thực hiện"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Chỉ cần nhìn vào camera và làm theo hướng dẫn."
                        android:textColor="#4F647B"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E4E9F2" />

            <!-- Item 2 -->
            <LinearLayout
                android:id="@+id/itemSecurity"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/face_bg_icon_blue">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Bảo mật"
                        android:src="@drawable/face_ic_lock"
                        app:tint="#1F6FEB" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bảo mật dữ liệu"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Ưu tiên lưu đặc trưng khuôn mặt thay vì ảnh gốc."
                        android:textColor="#4F647B"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Note -->
        <LinearLayout
            android:id="@+id/faceNoteBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/face_bg_note_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/face_bg_note_icon"
                android:gravity="center"
                android:text="i"
                android:textColor="#1F6FEB"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFaceNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:lineSpacingExtra="2dp"
                android:text="Dữ liệu sau khi xử lý sẽ được dùng để so khớp trong quá trình điểm danh QR + Face."
                android:textColor="#4F647B"
                android:textSize="13sp" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartFaceRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Bắt đầu đăng ký"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#1F6FEB"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipFaceRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Để sau"
            android:textAllCaps="false"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="14dp"
            app:strokeColor="#E4E9F2"
            app:strokeWidth="1dp" />

        <!-- Hidden legacy views: giữ ID dự phòng nếu code cũ gọi -->
        <LinearLayout
            android:id="@+id/legacyHiddenViews"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="0dp"
                android:layout_height="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>