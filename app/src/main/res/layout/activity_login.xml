<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/loginRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="100dp"
        android:paddingBottom="32dp">

        <!-- Logo app -->
        <LinearLayout
            android:id="@+id/logoContainer"
            android:layout_width="90dp"
            android:layout_height="78dp"
            android:background="@drawable/login_bg_logo_soft_blue"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Logo Smart Attendance"
                android:src="@drawable/login_ic_attendance_check"
                app:tint="#106AF0" />

        </LinearLayout>

        <!-- Tên app -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Smart Attendance"
            android:textColor="#111827"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Mô tả -->


        <!-- Form đăng nhập -->
        <LinearLayout
            android:id="@+id/loginForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:orientation="vertical">

            <!-- Label username -->
            <TextView
                android:id="@+id/tvUsernameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL HOẶC TÊN ĐĂNG NHẬP"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Ô nhập username -->
            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/login_bg_input_white"
                android:hint="Nhập email hoặc MSSV"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp" />

            <!-- Gợi ý username -->
            <TextView
                android:id="@+id/tvUsernameHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ví dụ: 23520001@gm.uit.edu.vn Hoặc 23520001"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <!-- Label password -->
            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="MẬT KHẨU"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Ô nhập mật khẩu + icon eye -->
            <FrameLayout
                android:id="@+id/passwordContainer"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/login_bg_input_white">

                <EditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Nhập mật khẩu"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="52dp"
                    android:singleLine="true"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/imgTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/login_ic_eye"
                    app:tint="#3C3131"
                    android:contentDescription="Hiện hoặc ẩn mật khẩu" />

            </FrameLayout>

            <!-- Quên mật khẩu -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:text="Quên mật khẩu?"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Error message - mặc định ẩn -->
            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/login_bg_error_box"
                android:padding="14dp"
                android:text="Sai tài khoản hoặc mật khẩu."
                android:textColor="#B91C1C"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Nút đăng nhập -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:text="Đăng nhập"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#ED185AE0"
                app:cornerRadius="14dp" />

        </LinearLayout>





        <!-- Hidden legacy views: giữ lại id cũ để code cũ không bị lỗi khi test UI -->
        <LinearLayout
            android:id="@+id/legacyHiddenViews"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <EditText
                android:id="@+id/passwordEditText"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/loginButton"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/registerText"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="0dp"
                android:layout_height="0dp" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>