<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- CLASS NAME -->
    <TextView
        android:id="@+id/tvClassName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text=""
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- INSTRUCTION -->

    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Yêu cầu sinh viên quét mã để điểm danh"
        android:textColor="#777777"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvClassName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- QR CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInstruction">

        <ImageView
            android:id="@+id/imgQR"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:padding="20dp"
            android:scaleType="fitCenter" />

    </androidx.cardview.widget.CardView>

    <!-- TIMER -->

    <!-- BUTTON AREA -->
    <LinearLayout
        android:id="@+id/layoutTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardView"
        tools:ignore="NotSibling">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#D32F2F" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Mã làm mới sau: 00:30"
            android:textColor="#D32F2F"
            android:textStyle="bold" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- GIỮ ID -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAttendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Xem danh sách sinh viên"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="#4A7DBF"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_view" />

        <!-- GIỮ ID -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSession"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Kết thúc điểm danh"
            android:textAllCaps="false"
            android:textColor="#D32F2F"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:strokeColor="#D32F2F" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
