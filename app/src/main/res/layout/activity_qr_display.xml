<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/qrDisplayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ScrollView
        android:id="@+id/qrDisplayScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/qrDisplayContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="108dp">

            <!-- Top bar -->
            <LinearLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="8dp"
                android:paddingEnd="20dp">

                <FrameLayout
                    android:id="@+id/btnBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/qr_bg_icon_button">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Quay lại"
                        android:src="@drawable/qr_ic_arrow_back"
                        app:tint="#111827" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvTopTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Điểm danh"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="42dp"
                    android:layout_height="42dp" />

            </LinearLayout>

            <!-- Session info -->
            <LinearLayout
                android:id="@+id/sessionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="6dp"
                android:paddingEnd="22dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvCourseCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="NT116.P12"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSessionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:text="Buổi 3 · QR + Face"
                    android:textColor="#4F647B"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- QR Card -->

            <!-- Stats -->
            <LinearLayout
                android:id="@+id/qrCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/qr_bg_card"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- QR title row -->
                <LinearLayout
                    android:id="@+id/qrTitleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvQrLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MÃ ĐIỂM DANH"
                        android:textColor="#7D8CA1"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSessionStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/qr_bg_badge_green"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="Đang mở"
                        android:textColor="#15935B"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- QR area -->
                <FrameLayout
                    android:id="@+id/qrBox"
                    android:layout_width="260dp"
                    android:layout_height="250dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/qr_bg_qr_box">

                    <!-- Sau này code Kotlin sẽ generate bitmap QR vào ImageView này -->
                    <ImageView
                        android:id="@+id/imgQrCode"
                        android:layout_width="208dp"
                        android:layout_height="223dp"
                        android:layout_gravity="center"
                        android:contentDescription="QR điểm danh"
                        android:scaleType="fitCenter"
                        android:src="@drawable/qr_placeholder_pattern" />

                </FrameLayout>

                <!-- Timer badge -->
                <TextView
                    android:id="@+id/tvQrRefreshTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/qr_bg_badge_red"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="Làm mới sau 00:24"
                    android:textColor="#D83A3A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sessionStatsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/qr_bg_card"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:id="@+id/statPresentBox"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/qr_bg_stat_box"
                    android:orientation="vertical"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/tvPresentCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="35"
                        android:textColor="#111827"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPresentLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Đã điểm danh"
                        android:textColor="#4F647B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statAbsentBox"
                    android:layout_width="0dp"
                    android:layout_height="92dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/qr_bg_stat_box"
                    android:orientation="vertical"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/tvAbsentCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#111827"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAbsentLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Còn vắng"
                        android:textColor="#4F647B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Recent attendance -->
            <TextView
                android:id="@+id/tvRecentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="20dp"
                android:text="VỪA ĐIỂM DANH"
                android:textColor="#7D8CA1"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/recentListCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/qr_bg_card"
                android:orientation="vertical">

                <!-- Recent item 1 -->
                <LinearLayout
                    android:id="@+id/recentItemOne"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/qr_bg_avatar_blue"
                        android:gravity="center"
                        android:text="NA"
                        android:textColor="#1F6FEB"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRecentNameOne"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Nguyễn Thị A"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRecentInfoOne"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="08:02:14 · QR + Face"
                            android:textColor="#4F647B"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRecentBadgeOne"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/qr_bg_badge_green"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="✓"
                        android:textColor="#15935B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E4E9F2" />

                <!-- Recent item 2 -->
                <LinearLayout
                    android:id="@+id/recentItemTwo"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/qr_bg_avatar_blue"
                        android:gravity="center"
                        android:text="TB"
                        android:textColor="#1F6FEB"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRecentNameTwo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Trần Văn B"
                            android:textColor="#111827"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRecentInfoTwo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="08:05:33 · QR + Face"
                            android:textColor="#4F647B"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRecentBadgeTwo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/qr_bg_badge_green"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="✓"
                        android:textColor="#15935B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom fixed action -->
    <LinearLayout
        android:id="@+id/bottomActionBar"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="@drawable/qr_bg_bottom_action"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp"
        android:paddingTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSession"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Kết thúc điểm danh"
            android:textAllCaps="false"
            android:textColor="#D83A3A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="14dp"
            app:strokeColor="#F5B5B5"
            app:strokeWidth="1dp" />

    </LinearLayout>

</FrameLayout>