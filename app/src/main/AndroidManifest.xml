<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.smartattendance">

    <!-- ===================== -->
    <!-- PERMISSIONS -->
    <!-- ===================== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- ===================== -->
    <!-- APPLICATION -->
    <!-- ===================== -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartAttendance">

        <!-- ===================== -->
        <!-- SPLASH (ENTRY POINT) -->
        <!-- ===================== -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===================== -->
        <!-- AUTH -->
        <!-- ===================== -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- STUDENT -->
        <!-- ===================== -->
        <activity
            android:name=".ui.student.StudentDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.student.ScanQRActivity"
            android:exported="false" />

        <activity
            android:name=".ui.student.FaceRegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.student.FaceVerifyActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- LECTURER -->
        <!-- ===================== -->
        <activity
            android:name=".ui.lecturer.LecturerHomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.lecturer.CreateClassActivity"
            android:exported="false" />

        <activity
            android:name=".ui.lecturer.QRDisplayActivity"
            android:exported="false" />

        <!-- DANH SÁCH ĐIỂM DANH -->
        <activity
            android:name=".ui.lecturer.AttendanceListActivity"
            android:exported="false" />

        <activity
            android:name=".ui.lecturer.LecturerSessionListActivity"
            android:exported="false"/>


    </application>

</manifest>
